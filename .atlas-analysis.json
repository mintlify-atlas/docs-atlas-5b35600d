{
  "projectType": "sdk-library",
  "projectName": "Screaming Frog API",
  "projectDescription": "A Python library for querying Screaming Frog SEO Spider crawl data programmatically, supporting Derby, DuckDB, CSV, and SQLite backends.",
  "theme": "luma",
  "primaryColor": "#7c7c80",
  "lightColor": "#151c28",
  "darkColor": "#f2f2f2",
